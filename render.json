{
  "buildCommand": "cd server && npm install --legacy-peer-deps && npm run build",
  "startCommand": "cd server && npm run start:prod",
  "envVars": [
    {
      "key": "DATABASE_URL",
      "fromDatabase": {
        "name": "production_management",
        "engine": "postgres"
      }
    },
    {
      "key": "NODE_ENV",
      "value": "production"
    },
    {
      "key": "JWT_SECRET",
      "value": "your_jwt_secret_here_change_me"
    }
  ]
}
