{
  "name": "production-management-backend",
  "version": "1.0.0",
  "description": "Simple file-based backend for Production Management System",
  "type": "module",
  "main": "server-postgres.js",
  "scripts": {
    "start": "node server-prisma.js",
    "start:json": "node server.js",
    "start:prisma": "node server-prisma.js",
    "dev": "node --watch server-prisma.js",
    "dev:json": "node --watch server.js",
    "dev:prisma": "node --watch server-prisma.js",
    "build": "prisma generate",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "prisma:studio": "prisma studio",
    "prisma:seed": "node prisma/seed.js",
    "reset:db": "node reset-db.js",
    "delete:user": "node delete-user.js",
    "fix:db": "node check-and-fix-db.js",
    "kill-port": "lsof -ti:5000 | xargs kill -9 || true",
    "start:clean": "npm run kill-port && node server.js"
  },
  "keywords": [
    "production",
    "management",
    "backend",
    "express"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@prisma/client": "^4.16.2",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^17.4.1",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.11.3"
  },
  "devDependencies": {
    "prisma": "^4.16.2"
  }
}
