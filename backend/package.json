{
  "name": "production-management-backend",
  "version": "1.0.0",
  "description": "Simple file-based backend for Production Management System",
  "type": "module",
  "main": "server-postgres.js",
  "scripts": {
    "start": "node server-postgres.js",
    "start:json": "node server.js",
    "dev": "node --watch server-postgres.js",
    "dev:json": "node --watch server.js",
    "kill-port": "lsof -ti:5000 | xargs kill -9 || true",
    "start:clean": "npm run kill-port && node server.js"
  },
  "keywords": [
    "production",
    "management",
    "backend",
    "express"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.11.3"
  }
}
