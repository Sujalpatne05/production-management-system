// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Company table
model Company {
  id                String   @id @default(cuid())
  name              String
  email             String?  @unique
  phone             String?
  address           String?
  website           String?
  logo              String?
  subscriptionPlan  String   @default("starter")
  subscriptionStatus String  @default("active")
  maxUsers          Int      @default(10)
  maxStorage        Int      @default(1000) // in MB
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  deletedAt         DateTime?

  // Relations
  admins            CompanyAdmin[]
  subscriptions     Subscription[]
  auditLogs         AuditLog[]
  supportTickets    SupportTicket[]
  users             User[]
  
  @@index([email])
  @@index([subscriptionStatus])
}

// Company Admin table
model CompanyAdmin {
  id        String   @id @default(cuid())
  companyId String
  userId    String
  role      String   @default("admin") // admin, super_admin
  status    String   @default("active")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([companyId, userId])
  @@index([companyId])
  @@index([userId])
}

// Subscription Plan table
model SubscriptionPlan {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  price       Decimal  @db.Decimal(10, 2)
  billingCycle String  @default("monthly") // monthly, yearly
  maxUsers    Int
  maxStorage  Int      // in MB
  features    Json?    // Array of feature names
  status      String   @default("active")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  subscriptions Subscription[]

  @@index([status])
}

// Subscription table
model Subscription {
  id        String   @id @default(cuid())
  companyId String
  planId    String
  startDate DateTime
  endDate   DateTime?
  status    String   @default("active") // active, expired, cancelled
  autoRenew Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  company   Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  plan      SubscriptionPlan  @relation(fields: [planId], references: [id])

  @@index([companyId])
  @@index([status])
}

// Audit Log table
model AuditLog {
  id            String   @id @default(cuid())
  companyId     String?
  userId        String?
  action        String   // create, update, delete, login, logout
  resourceType  String   // user, company, order, etc
  resourceId    String?
  changes       Json?    // What changed
  ipAddress     String?
  userAgent     String?
  status        String   @default("success") // success, failure
  errorMessage  String?
  createdAt     DateTime @default(now())

  // Relations
  company       Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)
  user          User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([companyId])
  @@index([userId])
  @@index([action])
  @@index([createdAt])
}

// Support Ticket table
model SupportTicket {
  id          String   @id @default(cuid())
  companyId   String
  subject     String
  description String
  status      String   @default("open") // open, in_progress, resolved, closed
  priority    String   @default("medium") // low, medium, high, urgent
  assignedTo  String?
  attachments Json?    // Array of file URLs
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  resolvedAt  DateTime?

  // Relations
  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  assignee    User?    @relation(fields: [assignedTo], references: [id], onDelete: SetNull)

  @@index([companyId])
  @@index([status])
  @@index([priority])
}

// Invoice table
model Invoice {
  id            String   @id @default(cuid())
  companyId     String
  invoiceNumber String   @unique
  subscriptionId String?
  amount        Decimal  @db.Decimal(15, 2)
  tax           Decimal  @default(0) @db.Decimal(15, 2)
  total         Decimal  @db.Decimal(15, 2)
  status        String   @default("pending") // pending, paid, overdue, cancelled
  dueDate       DateTime
  paidDate      DateTime?
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([companyId])
  @@index([status])
  @@index([dueDate])
}

// Payment table (for subscriptions)
model SubscriptionPayment {
  id            String   @id @default(cuid())
  invoiceId     String?
  companyId     String
  amount        Decimal  @db.Decimal(15, 2)
  paymentMethod String   // credit_card, bank_transfer, etc
  transactionId String?  @unique
  status        String   @default("pending") // pending, completed, failed
  failureReason String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([companyId])
  @@index([status])
}

// System Settings table
model SystemSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     Json?
  type      String   @default("string") // string, number, boolean, json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([key])
}

// API Key table
model ApiKey {
  id        String   @id @default(cuid())
  companyId String?
  name      String
  key       String   @unique
  secret    String   @unique
  status    String   @default("active")
  lastUsed  DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId])
  @@index([status])
}

// Users table
model User {
  id        String   @id @default(cuid())
  name      String
  username  String?  @unique
  email     String?  @unique
  password  String?
  passwordHash String?
  role      String   @default("user") // user, admin, super_admin
  status    String   @default("active")
  companyId String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  company       Company?        @relation(fields: [companyId], references: [id], onDelete: SetNull)
  adminRoles    CompanyAdmin[]
  auditLogs     AuditLog[]
  supportTickets SupportTicket[]

  @@index([email])
  @@index([username])
  @@index([role])
  @@index([companyId])
}

// Attendance table
model Attendance {
  id           String   @id @default(cuid())
  companyId    String?
  employeeId   String?
  employeeName String?
  date         DateTime?
  inTime       String?
  outTime      String?
  status       String?
  note         String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([date])
  @@index([companyId])
}

// Orders table
model Order {
  id           String   @id @default(cuid())
  companyId    String?
  orderNumber  String   @unique
  customerId   String?
  customer     String?
  items        Json?
  total        Decimal  @db.Decimal(15, 2)
  paid         Decimal  @default(0) @db.Decimal(15, 2)
  due          Decimal? @db.Decimal(15, 2)
  date         DateTime?
  status       String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([date])
  @@index([companyId])
}

// Production table
model Production {
  id           String   @id @default(cuid())
  companyId    String?
  referenceNo  String?
  productId    String?
  quantity     Int?
  startDate    DateTime?
  endDate      DateTime?
  status       String?
  stage        String?
  notes        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([companyId])
}

// Sales table
model Sale {
  id           String   @id @default(cuid())
  companyId    String?
  invoiceNo    String   @unique
  customerId   String?
  customer     String?
  items        Json?
  total        Decimal  @db.Decimal(15, 2)
  paid         Decimal  @default(0) @db.Decimal(15, 2)
  due          Decimal? @db.Decimal(15, 2)
  date         DateTime?
  status       String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([date])
  @@index([companyId])
}

// Purchases table
model Purchase {
  id           String   @id @default(cuid())
  companyId    String?
  invoiceNo    String?
  supplierId   String?
  supplier     String?
  items        Json?
  total        Decimal  @db.Decimal(15, 2)
  paid         Decimal  @default(0) @db.Decimal(15, 2)
  due          Decimal? @db.Decimal(15, 2)
  date         DateTime?
  status       String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([date])
  @@index([companyId])
}

// Inventory table
model Inventory {
  id           String   @id @default(cuid())
  companyId    String?
  sku          String   @unique
  name         String
  category     String?
  quantity     Int      @default(0)
  unitPrice    Decimal? @db.Decimal(15, 2)
  reorderLevel Int?
  supplier     String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([companyId])
}

// Expenses table
model Expense {
  id            String   @id @default(cuid())
  companyId     String?
  categoryId    String?
  category      String?
  amount        Decimal  @db.Decimal(15, 2)
  date          DateTime?
  description   String?
  paymentMethod String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([companyId])
}

// Payments table
model Payment {
  id            String   @id @default(cuid())
  companyId     String?
  type          String?
  partyId       String?
  partyName     String?
  amount        Decimal  @db.Decimal(15, 2)
  date          DateTime?
  paymentMethod String?
  reference     String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([companyId])
}

// Payroll table
model Payroll {
  id           String   @id @default(cuid())
  companyId    String?
  employeeId   String?
  employeeName String?
  month        String?
  basicSalary  Decimal  @db.Decimal(15, 2)
  bonus        Decimal  @default(0) @db.Decimal(15, 2)
  deductions   Decimal  @default(0) @db.Decimal(15, 2)
  netSalary    Decimal  @db.Decimal(15, 2)
  status       String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([companyId])
}

// Outlets table
model Outlet {
  id        String   @id @default(cuid())
  companyId String?
  name      String
  phone     String?
  email     String?
  address   String?
  status    String   @default("active")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId])
}

// Factories table
model Factory {
  id               String   @id @default(cuid())
  companyId        String
  name             String
  type             String   // "Main Office" or "Branch Office"
  location         String
  manager          String?
  employees        Int      @default(0)
  productionLines  Int      @default(0)
  storageCapacity  Decimal  @default(0) @db.Decimal(15, 2)
  storageUsed      Decimal  @default(0) @db.Decimal(15, 2)
  efficiency       Decimal  @default(0) @db.Decimal(5, 2)
  status           String   @default("active")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([companyId])
  @@index([type])
}

// Parties table (Customers & Suppliers)
model Party {
  id        String   @id @default(cuid())
  companyId String?
  name      String
  type      String?
  phone     String?
  email     String?
  address   String?
  balance   Decimal  @default(0) @db.Decimal(15, 2)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId])
}

// Quotations table
model Quotation {
  id           String   @id @default(cuid())
  companyId    String?
  quotationNo  String   @unique
  customerId   String?
  customer     String?
  items        Json?
  total        Decimal  @db.Decimal(15, 2)
  validUntil   DateTime?
  status       String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([companyId])
}

// Wastes table
model Waste {
  id       String   @id @default(cuid())
  companyId String?
  itemId   String?
  itemName String?
  type     String?
  quantity Int?
  date     DateTime?
  reason   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId])
}

// Settings table
model Setting {
  id        String   @id @default(cuid())
  companyId String?
  key       String
  value     Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([companyId, key])
  @@index([companyId])
}

// Reports table
model Report {
  id        String   @id @default(cuid())
  companyId String?
  name      String
  type      String?
  data      Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId])
}

// Accounting table
model Accounting {
  id            String   @id @default(cuid())
  companyId     String?
  accountName   String?
  type          String?
  balance       Decimal  @default(0) @db.Decimal(15, 2)
  accountNumber String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([companyId])
}

// Product Categories table
model ProductCategory {
  id          String   @id @default(cuid())
  companyId   String?
  name        String
  description String?
  status      String   @default("active")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([companyId])
}

// Raw Material Categories table
model RMCategory {
  id          String   @id @default(cuid())
  companyId   String?
  name        String
  description String?
  status      String   @default("active")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([companyId])
}

// Expense Categories table
model ExpenseCategory {
  id          String   @id @default(cuid())
  companyId   String?
  name        String
  description String?
  status      String   @default("active")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([companyId])
}

// Non-Inventory Items table
model NonInventoryItem {
  id          String   @id @default(cuid())
  companyId   String?
  name        String
  category    String?
  description String?
  unitPrice   Decimal? @db.Decimal(15, 2)
  status      String   @default("active")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([companyId])
}

// Accounts table
model Account {
  id            String   @id @default(cuid())
  companyId     String?
  accountName   String
  accountCode   String   @unique
  accountType   String?
  parentAccount String?
  balance       Decimal  @default(0) @db.Decimal(15, 2)
  status        String   @default("active")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([accountCode])
  @@index([companyId])
}

// Transactions table
model Transaction {
  id            String   @id @default(cuid())
  companyId     String?
  transactionNo String   @unique
  date          DateTime?
  accountId     String?
  debit         Decimal  @default(0) @db.Decimal(15, 2)
  credit        Decimal  @default(0) @db.Decimal(15, 2)
  description   String?
  reference     String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([date])
  @@index([accountId])
  @@index([companyId])
}

// Units table
model Unit {
  id        String   @id @default(cuid())
  companyId String?
  name      String
  symbol    String?
  type      String?
  status    String   @default("active")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId])
}
