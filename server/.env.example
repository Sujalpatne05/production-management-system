# Database connection
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DBNAME?schema=public"

# Redis
REDIS_URL="redis://localhost:6379"

# JWT / Auth
JWT_PUBLIC_KEY="replace-with-keycloak-public-key"
JWT_ISSUER="https://your-keycloak/realms/your-realm"
JWT_SECRET="your-jwt-secret-key-here"
JWT_EXPIRES_IN="7d"

# CORS Configuration for frontend domains
# Format: comma-separated list of allowed origins
# Add your Vercel frontend URL and any dev URLs
CORS_ORIGIN="https://production-management-system-drab.vercel.app,https://localhost:3000,https://localhost:8081,http://localhost:5173,http://localhost:8081,http://127.0.0.1:8081,*.vercel.app"

# Email Configuration (Render-safe: prefer Brevo API)
BREVO_API_KEY="your-brevo-api-key"
MAIL_FROM_NAME="IProduction"
MAIL_HOST="smtp.gmail.com"
MAIL_PORT=587
MAIL_USER="your-email@gmail.com"
MAIL_PASSWORD="your-app-specific-password"
MAIL_FROM="noreply@iproduction.com"

# BullMQ
BULLMQ_PREFIX="prodmgmt"
