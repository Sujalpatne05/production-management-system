# Database connection
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DBNAME?schema=public"

# Redis
REDIS_URL="redis://localhost:6379"

# JWT / Auth
JWT_PUBLIC_KEY="replace-with-keycloak-public-key"
JWT_ISSUER="https://your-keycloak/realms/your-realm"
JWT_SECRET="your-jwt-secret-key-here"
JWT_EXPIRES_IN="7d"

# Email Configuration (Render-safe: prefer Brevo API)
BREVO_API_KEY="your-brevo-api-key"
MAIL_FROM_NAME="IProduction"
MAIL_HOST="smtp.gmail.com"
MAIL_PORT=587
MAIL_USER="your-email@gmail.com"
MAIL_PASSWORD="your-app-specific-password"
MAIL_FROM="noreply@iproduction.com"

# BullMQ
BULLMQ_PREFIX="prodmgmt"
