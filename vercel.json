{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "env": {
    "VITE_API_URL": {
      "description": "Backend API URL",
      "required": true
    },
    "VITE_BASE_URL": {
      "description": "Backend base URL",
      "required": true
    },
    "VITE_WS_URL": {
      "description": "WebSocket URL",
      "required": false
    }
  },
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
